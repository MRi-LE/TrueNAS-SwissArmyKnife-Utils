# ──────────────────────────────────────────────────────────────────────────────
# truenas-config-backup  —  example configuration
# Copy to .env and fill in your values.
# chmod 600 .env
#
# IMPORTANT: inline comments are not supported.
# Write comments on their own lines only. This does NOT work:
#   TRUENAS_HOST=truenas.local  # my NAS   <- the comment becomes part of the value
# ──────────────────────────────────────────────────────────────────────────────

# TrueNAS connection ──────────────────────────────────────────────────────────

# Hostname or IP of your TrueNAS server (no https://)
TRUENAS_HOST=truenas.local

# API key: TrueNAS UI → Settings → API Keys → Add
TRUENAS_API_KEY=1-xxxxxxxxxxxxxxxx

# Set to false only for self-signed certs on a trusted network.
# Requires truenas_api_client >= 25.10. See README for details.
TRUENAS_VERIFY_SSL=true

# Set to true for TrueNAS <= 24.10 (CORE or older SCALE)
TRUENAS_LEGACY_WS=false

# Download behaviour ──────────────────────────────────────────────────────────

# Buffered mode keeps the download URL valid longer (recommended for most setups).
# Set to false only if you have a specific reason to use streaming mode.
TRUENAS_BUFFERED_DOWNLOAD=true

# Bundle options — what config.save includes.
# At least ONE of these must be true, or TrueNAS returns a bare .db instead of a
# tar archive (validation will reject all-false).
# secret seed (pwenc_secret): required to restore passwords on different hardware.
TRUENAS_SECRET_SEED=true
# include /root/.ssh/authorized_keys in the archive.
TRUENAS_ROOT_AUTHORIZED_KEYS=false

# Backup storage ──────────────────────────────────────────────────────────────

# Absolute path; created automatically if it does not exist
BACKUP_DIR=/mnt/backups/truenas-config

# Retention limits ────────────────────────────────────────────────────────────

# Number of daily backups to keep
RETAIN_DAILY=7

# Number of weekly backups to keep (taken every Sunday)
RETAIN_WEEKLY=4

# Number of monthly backups to keep (taken on the 1st of each month)
RETAIN_MONTHLY=2

# E-mail notifications ────────────────────────────────────────────────────────

# When to send notifications: always | failure | never
NOTIFY_ON=failure

# Recipient address (leave blank to disable notifications)
NOTIFY_EMAIL=

SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=truenas-backup@example.com

# Logging ─────────────────────────────────────────────────────────────────────

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log file path (defaults to {BACKUP_DIR}/backup.log if not set)
# LOG_FILE=
